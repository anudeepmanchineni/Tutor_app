# ============================================================
# Koshly — Environment Variables Template
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ------------------------------------------------------------
# Google OAuth (configured inside Supabase Auth dashboard)
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# ------------------------------------------------------------
# AI / LLM
# ------------------------------------------------------------
GEMINI_API_KEY=your_google_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ------------------------------------------------------------
# Razorpay
# ------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ------------------------------------------------------------
# FastAPI Backend
# ------------------------------------------------------------
APP_ENV=development
SECRET_KEY=your_random_secret_key_for_jwt_or_sessions
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ------------------------------------------------------------
# Flutter (used via --dart-define-from-file)
# These are client-safe values only — no server secrets here.
# ------------------------------------------------------------
FLUTTER_SUPABASE_URL=https://your-project-id.supabase.co
FLUTTER_SUPABASE_ANON_KEY=your_supabase_anon_key_here
FLUTTER_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
FLUTTER_API_BASE_URL=http://localhost:8000
